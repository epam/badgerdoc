# BadgerDoc API URL - leave empty to use Vite proxy (default: /badgerdoc)
# VITE_BADGERDOC_API_URL=/badgerdoc

# BadgerDoc Authentication (in priority order):
# 1. Bearer token (recommended for production)
# VITE_BADGERDOC_TOKEN=your-token-here
#
# 2. Basic Auth (if token not set but username is provided)
# VITE_BADGERDOC_USERNAME=admin
# VITE_BADGERDOC_PASSWORD=123
#
# 3. Session cookies (if neither token nor username is set)
#    Login via Django admin (/admin) and cookies will be used automatically

# Per-domain mock overrides
# Default: uses REAL API
# Set VITE_MOCK_{DOMAIN}=true to use mock data instead
# VITE_MOCK_EXTRACTIONS=true
# VITE_MOCK_DOCUMENTS=true
# VITE_MOCK_TASKS=true
# VITE_MOCK_TAGS=true

# Global mock fallback (set to 'true' to enable mocks for all domains)
# VITE_USE_MOCK_FALLBACK=true

# VITE_APP_NAME=HITL Platform
